grocery-app.env.local

# iOS secrets — contains Supabase credentials
ios/SGO.xcconfig

# Xcode generated / derived
ios/*.xcodeproj/project.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/DerivedData/
ios/.build/

# Xcode UI/user state
*.xcuserstate
*.xcscmblueprint
*.xcuserdatad/
*.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings

# App icon PNGs (if not source)
ios/SmartGroceryOptimizer/SmartGroceryOptimizer/SmartGroceryOptimizer/Assets.xcassets/AppIcon.appiconset/*.png

# Test helpers (secrets)
tests/helpers/auth.ts

# Local-only unit tests (optional)
tests/unit/

